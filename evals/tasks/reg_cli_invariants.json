{
  "id": "reg_cli_invariants",
  "name": "Add ledger ping subcommand (regression: existing add/list/id invariants must hold)",
  "suite": "capability",
  "family": "guardrail",
  "difficulty": "easy",
  "tags": ["guardrail", "regression", "ping", "cli"],
  "prompt": "Add a `ping` subcommand to the ledger CLI that prints {\"pong\": true} as a single JSON line to stdout and exits 0. Make minimal, maintainable changes that keep existing behavior and tests passing.",
  "seed_scenario": "evals/scenarios/cli_ledger_seed",
  "overlays": [],
  "grader_overlays": ["evals/grader_overlays/reg_cli_invariants"],
  "memory_seed": [],
  "warmup": [],
  "requirements": [
    {
      "id": "ping_exits_zero",
      "description": "ping exits 0",
      "command": "python -m pytest -q tests/test_reg_cli_invariants.py::test_ping_exits_zero"
    },
    {
      "id": "ping_pong_json",
      "description": "ping prints {\"pong\": true} as a JSON line to stdout",
      "command": "python -m pytest -q tests/test_reg_cli_invariants.py::test_ping_prints_pong_json"
    },
    {
      "id": "ping_no_stderr",
      "description": "ping writes nothing to stderr on success",
      "command": "python -m pytest -q tests/test_reg_cli_invariants.py::test_ping_nothing_on_stderr"
    },
    {
      "id": "reg_add_three_list_three",
      "description": "add 3 entries, list shows exactly 3 (existing behavior)",
      "command": "python -m pytest -q tests/test_reg_cli_invariants.py::test_add_three_list_shows_three"
    },
    {
      "id": "reg_ids_strictly_increasing",
      "description": "ids from list are strictly increasing after 3 adds (existing behavior)",
      "command": "python -m pytest -q tests/test_reg_cli_invariants.py::test_ids_strictly_increasing"
    },
    {
      "id": "reg_ids_unique",
      "description": "3 adds produce 3 distinct ids (existing behavior)",
      "command": "python -m pytest -q tests/test_reg_cli_invariants.py::test_ids_unique_across_three_adds"
    }
  ],
  "timeout_seconds": 300,
  "max_budget_usd": 1.0,
  "graders": {
    "outcome": ["python -m pytest -q tests/test_reg_cli_invariants.py"],
    "regression": ["python -m pytest -q tests/test_ledger_baseline.py"],
    "static": ["ruff check ledger tests", "mypy ledger"]
  }
}

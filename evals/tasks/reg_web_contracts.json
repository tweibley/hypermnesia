{
  "id": "reg_web_contracts",
  "name": "Add GET /ping and verify existing API contracts are unchanged",
  "suite": "regression",
  "family": "guardrail",
  "difficulty": "easy",
  "tags": ["regression", "contracts", "ping", "health"],
  "prompt": "Add a GET /ping endpoint that returns {\"pong\": true} with a 200 status code. Make minimal changes and keep all existing behavior and tests passing.",
  "seed_scenario": "evals/scenarios/python_webapp_seed",
  "overlays": [],
  "grader_overlays": ["evals/grader_overlays/reg_web_contracts"],
  "memory_seed": [],
  "warmup": [],
  "requirements": [
    {
      "id": "ping_works",
      "description": "GET /ping returns 200 with {\"pong\": true}",
      "command": "python -m pytest -q tests/test_reg_web_contracts.py::test_ping_returns_pong"
    },
    {
      "id": "health_contract",
      "description": "GET /health still returns {\"status\": \"ok\"}",
      "command": "python -m pytest -q tests/test_reg_web_contracts.py::test_health_contract"
    },
    {
      "id": "users_contract",
      "description": "GET /users still returns exactly 3 users",
      "command": "python -m pytest -q tests/test_reg_web_contracts.py::test_users_contract"
    },
    {
      "id": "viewer_403_contract",
      "description": "PATCH /tasks/{id} by a viewer (actor_id=3) still returns 403",
      "command": "python -m pytest -q tests/test_reg_web_contracts.py::test_viewer_patch_still_403"
    }
  ],
  "timeout_seconds": 300,
  "max_budget_usd": 0.5,
  "graders": {
    "outcome": ["python -m pytest -q tests/test_reg_web_contracts.py"],
    "regression": ["python -m pytest -q tests/test_health.py tests/test_tasks_baseline.py"],
    "static": ["ruff check app tests", "mypy app"]
  }
}

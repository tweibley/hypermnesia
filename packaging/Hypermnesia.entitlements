<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Notch click-back focuses the exact terminal/IDE tab via Apple Events. Hardened runtime
       blocks AE without this entitlement; the usage string lives in Info.plist. -->
  <key>com.apple.security.automation.apple-events</key>
  <true/>
</dict>
</plist>
